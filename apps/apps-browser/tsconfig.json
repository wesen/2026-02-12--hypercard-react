{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "paths": {
      "@hypercard/desktop-os": ["../../packages/desktop-os/src"],
      "@hypercard/engine": ["../../packages/engine/src"],
      "@hypercard/chat-runtime": ["../../packages/chat-runtime/src"],
      "@hypercard/hypercard-runtime": ["../../packages/hypercard-runtime/src"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../../packages/desktop-os" },
    { "path": "../../packages/engine" },
    { "path": "../../packages/chat-runtime" },
    { "path": "../../packages/hypercard-runtime" }
  ]
}
