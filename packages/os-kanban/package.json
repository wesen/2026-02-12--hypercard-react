{
  "name": "@go-go-golems/os-kanban",
  "version": "0.1.0",
  "description": "Kanban runtime modules and host registration helpers for go-go-os.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Manuel Odendahl",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/go-go-golems/go-go-os-frontend.git",
    "directory": "packages/os-kanban"
  },
  "homepage": "https://github.com/go-go-golems/go-go-os-frontend/tree/main/packages/os-kanban#readme",
  "bugs": {
    "url": "https://github.com/go-go-golems/go-go-os-frontend/issues"
  },
  "files": [
    "**/*.js",
    "**/*.d.ts",
    "**/*.css",
    "**/*.vm.js",
    "**/*.json",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": "./src/index.ts",
    "./theme": "./src/theme/index.ts"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -b",
    "build:dist": "node ../../scripts/packages/build-dist.mjs",
    "typecheck": "tsc -b",
    "test": "vitest run src",
    "test:watch": "vitest src"
  },
  "dependencies": {
    "@go-go-golems/os-core": "workspace:*",
    "@go-go-golems/os-scripting": "workspace:*",
    "@go-go-golems/os-widgets": "workspace:*",
    "@go-go-golems/os-ui-cards": "workspace:*"
  },
  "peerDependencies": {
    "@reduxjs/toolkit": "^2.0.0",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "react-redux": "^9.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
