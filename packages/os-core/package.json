{
  "name": "@go-go-golems/os-core",
  "version": "0.1.0",
  "description": "Core desktop widgets, theming, Redux helpers, and shell primitives for go-go-os.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Manuel Odendahl",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/go-go-golems/go-go-os-frontend.git",
    "directory": "packages/os-core"
  },
  "homepage": "https://github.com/go-go-golems/go-go-os-frontend/tree/main/packages/os-core#readme",
  "bugs": {
    "url": "https://github.com/go-go-golems/go-go-os-frontend/issues"
  },
  "files": [
    "**/*.js",
    "**/*.d.ts",
    "**/*.css",
    "**/*.vm.js",
    "**/*.json",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "exports": {
    ".": "./src/index.ts",
    "./desktop-core": "./src/desktop-core.ts",
    "./desktop-react": "./src/desktop-react.ts",
    "./desktop-theme-macos1": "./src/desktop-theme-macos1.ts",
    "./theme": "./src/theme/index.ts",
    "./theme/classic.css": "./src/theme/classic.css",
    "./theme/modern.css": "./src/theme/modern.css"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -b",
    "build:dist": "node ../../scripts/packages/build-dist.mjs",
    "typecheck": "tsc -b",
    "test": "node ../../scripts/storybook/check-taxonomy.mjs && vitest run",
    "test:watch": "node ../../scripts/storybook/check-taxonomy.mjs && vitest"
  },
  "dependencies": {
    "debug": "^4.4.3"
  },
  "peerDependencies": {
    "@reduxjs/toolkit": "^2.0.0",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "react-redux": "^9.0.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
